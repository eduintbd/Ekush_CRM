# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="https://ekush.aibd.ai"
NEXTAUTH_SECRET="generate-a-random-secret"

# File Storage
UPLOAD_DIR="./uploads"

# Unit Certificate QR verification
# Generate with: openssl rand -base64 48
CERTIFICATE_HMAC_SECRET="change-me-min-32-bytes-random-secret"
# Optional: base URL the QR code points to (defaults to NEXTAUTH_URL)
CERTIFICATE_VERIFICATION_BASE_URL="https://ekush.aibd.ai"

# ─── Tier 1 Prospect feature flag (Phase 3+) ─────────────────────────
# All /api/prospects/* and /prospect/* routes return 404 unless this is
# "true". Default off so the flow ships dark and is enabled per env.
PROSPECTS_ENABLED="false"

# ─── SMS gateway for prospect OTPs ───────────────────────────────────
# Supported values: "console" (default — logs to server stdout, dev only),
# Bangladeshi providers ("alpha", "ssl") and "twilio" are scaffolded
# pending credentials. The route layer goes through getSmsProvider() so
# swapping the value here flips the active gateway with no code change.
PROSPECTS_SMS_PROVIDER="console"

# ─── Prospects admin tab "NEW" badge (Phase 6) ───────────────────────
# YYYY-MM-DD launch date. The /admin/prospects nav badge auto-hides
# 30 days after this date.
PROSPECTS_TAB_LAUNCH="2026-04-26"
