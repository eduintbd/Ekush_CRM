generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth & Identity ─────────────────────────────────────────────
// UserRole: INVESTOR, ADMIN, MANAGER, COMPLIANCE, SUPPORT, SUPER_ADMIN
// UserStatus: PENDING, ACTIVE, SUSPENDED, CLOSED

model User {
  id               String    @id @default(cuid())
  // Email is NOT unique — family members investing under different investor
  // codes may legitimately share a single email. Login resolves ambiguity by
  // preferring the investor-code match; email lookups use findFirst.
  email            String?
  phone            String?
  // Display name for staff users. Investors have their name on the Investor
  // row; staff accounts don't have an Investor relation so we store it here.
  fullName         String?
  passwordHash     String
  supabaseId       String?   @unique
  // Values are constrained by src/lib/roles.ts: SUPER_ADMIN | MAKER | CHECKER
  // | VIEWER for staff, or INVESTOR for end-user accounts.
  role             String    @default("INVESTOR")
  status           String    @default("PENDING") // INVITED | ACTIVE | LOCKED | DEACTIVATED | PENDING | SUSPENDED | CLOSED
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  // Who invited this user (staff only; investors self-register).
  createdById      String?

  createdBy     User?                @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers  User[]               @relation("UserCreatedBy")
  invitesSent   Invitation[]         @relation("InvitedBy")
  resetTokens   PasswordResetToken[]
  investor      Investor?
  auditLogs     AuditLog[]
  notifications Notification[]
  sessions      Session[]
  totp          UserTotp?

  @@index([status])
  @@index([role])
  @@index([email])
  @@map("users")
}

// Staff invitations. A Super Admin creates a row with a one-time token
// (hash is stored here; raw token is emailed). On acceptance, the invitee
// sets a password and we mark acceptedAt.
model Invitation {
  id          String    @id @default(cuid())
  email       String
  fullName    String
  role        String // SUPER_ADMIN | MAKER | CHECKER | VIEWER
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  note        String?
  invitedById String?

  invitedBy User? @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

// Self-serve password reset. One-time token; hash stored here, raw token
// emailed. usedAt marks the token as consumed so a second click 404s.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Investor ────────────────────────────────────────────────────
// InvestorType: INDIVIDUAL, COMPANY_ORGANIZATION, MUTUAL_FUND, PROVIDENT_FUND, GRATUITY_FUND

model Investor {
  id                 String    @id @default(cuid())
  userId             String    @unique
  investorCode       String    @unique
  name               String
  title              String?
  investorType       String    @default("INDIVIDUAL")
  nidNumber          String?
  tinNumber          String?
  dateOfBirth        DateTime?
  address            String?
  riskProfile        String?
  boId               String?
  // DP (Depository Participant) ID and brokerage house — completes the BO/demat
  // account triple. Populated from the 'BO ID- NEW / DP ID- NEW / Brokerage
  // House Name- NEW' columns in Investors Database.xlsx.
  dpId               String?
  brokerageHouse     String?
  // Family names — sourced from 'Father Name / Mother Name / Spouse Name'
  // columns in the Investors Database workbook. Used on printed forms.
  fatherName         String?
  motherName         String?
  spouseName         String?
  dividendOption     String    @default("CASH") // CASH | CIP
  // Digital signature image URL (optional — wet signature on file is the fallback).
  // Used on auto-generated DDI forms.
  signatureUrl       String?
  // Timestamp of the one-time welcome email sent on PENDING→ACTIVE approval.
  // Null means never sent — manual "Send Now" in the admin edit form uses
  // this flag to show the retry UI.
  welcomeEmailSentAt DateTime?

  // Tier-1→Tier-2 conversion attribution. Set when a logged-in Prospect
  // submits the existing 4-step KYC and an Investor row is created. Null
  // for direct sign-ups (no prior prospect record). 1:1 — one Prospect
  // converts to at most one Investor.
  linkedProspectId String?   @unique
  linkedProspect   Prospect? @relation(fields: [linkedProspectId], references: [id], onDelete: SetNull)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings        FundHolding[]
  transactions    Transaction[]
  dividends       Dividend[]
  taxCertificates TaxCertificate[]
  kycRecords      KycRecord[]
  bankAccounts    BankAccount[]
  nominees        Nominee[]
  consents        Consent[]
  documents       Document[]
  serviceRequests ServiceRequest[]
  sipPlans        SipPlan[]
  investmentGoals InvestmentGoal[]
  mailLogs        MailLog[]
  ddiInstructions DdiInstruction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("investors")
}

// ─── Fund ────────────────────────────────────────────────────────

model Fund {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  fundType      String?
  description   String?
  objective     String?
  inceptionDate DateTime?
  currentNav    Float     @default(0)
  previousNav   Float     @default(0)
  totalAum      Float     @default(0)
  totalUnits    Float     @default(0)
  faceValue     Float     @default(10)

  managementFeeRate Float @default(0)
  trusteeFeeRate    Float @default(0)
  custodianFeeRate  Float @default(0)
  entryLoad         Float @default(0)
  exitLoad          Float @default(0)
  minInvestment     Float @default(0)
  minSipAmount      Float @default(0)

  holdings            FundHolding[]
  transactions        Transaction[]
  navRecords          NavRecord[]
  dividends           Dividend[]
  dividendHistory     DividendHistory[]
  taxCertificates     TaxCertificate[]
  financialStatements FinancialStatement[]
  fundExpenses        FundExpense[]
  sipPlans            SipPlan[]
  fundReports         FundReport[]
  dailyUploads        DailyFundUpload[]
  ddiInstructions     DdiInstruction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("funds")
}

// ─── Fund Holding (per investor per fund) ────────────────────────

model FundHolding {
  id         String @id @default(cuid())
  investorId String
  fundId     String

  // Lump Sum fields
  lsUnitsBought      Float @default(0)
  lsUnitsSold        Float @default(0)
  lsCurrentUnits     Float @default(0)
  lsCostValue        Float @default(0)
  lsCostOfUnitsSold  Float @default(0)
  lsCostValueCurrent Float @default(0)
  lsRealizedGain     Float @default(0)
  lsWeight           Float @default(0)
  lsAvgCost          Float @default(0)
  lsMarketValue      Float @default(0)

  // SIP fields
  sipUnitsBought      Float @default(0)
  sipUnitsSold        Float @default(0)
  sipCurrentUnits     Float @default(0)
  sipCostValue        Float @default(0)
  sipCostOfUnitsSold  Float @default(0)
  sipCostValueCurrent Float @default(0)
  sipRealizedGain     Float @default(0)
  sipWeight           Float @default(0)
  sipAvgCost          Float @default(0)
  sipMarketValue      Float @default(0)

  // Consolidated
  totalUnitsBought      Float @default(0)
  totalUnitsSold        Float @default(0)
  boOpeningBalance      Float @default(0)
  totalCurrentUnits     Float @default(0)
  totalCostValueCurrent Float @default(0)
  avgCost               Float @default(0)
  nav                   Float @default(0)
  totalMarketValue      Float @default(0)
  totalSellableUnits    Float @default(0)
  marketValueSellable   Float @default(0)
  totalRealizedGain     Float @default(0)
  totalUnrealizedGain   Float @default(0)
  percentUnitsHold      Float @default(0)

  // Gross Dividend (from simpler fund files)
  grossDividend Float @default(0)

  // XIRR-based annualized return (from T. History sheet in INVESTORS.xlsx)
  annualizedReturn Float @default(0)

  // First purchase date (earliest LS/SIP transaction); used for return calculations
  firstPurchaseDate DateTime?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([investorId, fundId])
  @@index([fundId])
  @@map("fund_holdings")
}

// ─── Transaction ─────────────────────────────────────────────────
// Channel: LS, SIP
// Direction: BUY, SELL
// Status: PENDING, IN_PROCESS, EXECUTED, REJECTED

model Transaction {
  id              String   @id @default(cuid())
  investorId      String
  fundId          String
  channel         String // LS or SIP
  direction       String // BUY or SELL
  amount          Float    @default(0)
  nav             Float    @default(0)
  units           Float    @default(0)
  cumulativeUnits Float    @default(0)
  unitCapital     Float    @default(0)
  unitPremium     Float    @default(0)
  avgCostAtTime   Float    @default(0)
  realizedGain    Float    @default(0)
  costOfUnitsSold Float    @default(0)
  uniqueCode      String?
  orderDate       DateTime
  status          String   @default("EXECUTED")
  paymentMethod   String? // BANK_TRANSFER | DDI
  paymentRef      String?
  notes           String?

  investor       Investor        @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund           Fund            @relation(fields: [fundId], references: [id], onDelete: Cascade)
  ddiInstruction DdiInstruction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId, fundId])
  @@index([orderDate])
  @@index([status])
  @@map("transactions")
}

// ─── DDI Instruction (one-time buy via Direct Debit) ─────────────
// Created when an investor authorizes Ekush to pull the buy amount
// from their registered bank account instead of uploading a slip.
// Links 1:1 to a Transaction. Signature is optional — a null value
// means "use the wet signature on file at Ekush".

model DdiInstruction {
  id              String   @id @default(cuid())
  investorId      String
  fundId          String
  transactionId   String?  @unique
  amount          Float
  signatureUrl    String? // snapshot at signing time; null = wet sig on file
  termsAccepted   Boolean  @default(false)
  status          String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | EXECUTED | CANCELLED
  applicationDate DateTime @default(now())
  adminNotes      String?

  investor    Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund        Fund         @relation(fields: [fundId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([fundId])
  @@index([status])
  @@map("ddi_instructions")
}

// ─── NAV Record ──────────────────────────────────────────────────

model NavRecord {
  id             String   @id @default(cuid())
  fundId         String
  date           DateTime
  nav            Float
  // Authoritative cumulative dividend-adjusted total return % from the
  // upstream xlsx ("Investor Return" column). Source of truth — not
  // recomputed from NAV. Nullable for rows imported before the column
  // existed.
  investorReturn Float?
  buyUnit        Float?
  sellUnit       Float?
  dsex           Float?
  ds30           Float?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, date])
  @@map("nav_records")
}

// ─── Dividend ────────────────────────────────────────────────────
// DividendOption: CASH, CIP

model Dividend {
  id              String    @id @default(cuid())
  investorId      String
  fundId          String
  accountingYear  String?
  paymentDate     DateTime?
  totalUnits      Float     @default(0)
  dividendPerUnit Float     @default(0)
  grossDividend   Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  netDividend     Float     @default(0)
  dividendOption  String    @default("CASH")
  tinNumber       String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([investorId, fundId])
  @@map("dividends")
}

// ─── DividendHistory ────────────────────────────────────────────
// Admin-entered annual dividend rate per fund/year, surfaced on the
// ekushwml.com marketing site's Dividend History tab (columns: Year,
// Annual Dividend %). Kept separate from Dividend (which is per-
// investor-per-payout) because the per-investor aggregation doesn't
// reliably reproduce the headline number the business announces.
model DividendHistory {
  id                String  @id @default(cuid())
  fundId            String
  year              Int
  annualDividendPct Float
  // Free-form note shown on admin list only (e.g. "Interim", "Final").
  // Never surfaced on the public marketing site.
  note              String?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fundId, year])
  @@index([fundId])
  @@map("dividend_histories")
}

// ─── Tax Certificate ─────────────────────────────────────────────

model TaxCertificate {
  id         String @id @default(cuid())
  investorId String
  fundId     String

  periodStart DateTime?
  periodEnd   DateTime?

  beginningUnits          Float @default(0)
  beginningCostValue      Float @default(0)
  beginningMarketValue    Float @default(0)
  beginningUnrealizedGain Float @default(0)

  endingUnits          Float @default(0)
  endingCostValue      Float @default(0)
  endingMarketValue    Float @default(0)
  endingUnrealizedGain Float @default(0)

  totalUnitsAdded       Float @default(0)
  totalAdditionAtCost   Float @default(0)
  totalUnitsRedeemed    Float @default(0)
  totalRedemptionAtCost Float @default(0)
  netInvestment         Float @default(0)
  totalRealizedGain     Float @default(0)
  totalGrossDividend    Float @default(0)
  totalTax              Float @default(0)
  totalNetDividend      Float @default(0)
  navAtEnd              Float @default(0)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([investorId, fundId, periodEnd], name: "investorId_fundId_periodEnd")
  @@index([investorId, fundId])
  @@map("tax_certificates")
}

// ─── Financial Statement ─────────────────────────────────────────

model FinancialStatement {
  id          String    @id @default(cuid())
  fundId      String
  type        String // BS, IS, CF, EQUITY
  periodStart DateTime?
  periodEnd   DateTime?
  data        String // JSON stored as text (SQLite doesn't support Json)

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("financial_statements")
}

// ─── Fund Expense ────────────────────────────────────────────────

model FundExpense {
  id            String    @id @default(cuid())
  fundId        String
  periodStart   DateTime?
  periodEnd     DateTime?
  managementFee Float     @default(0)
  trusteeFee    Float     @default(0)
  custodianFee  Float     @default(0)
  auditFee      Float     @default(0)
  bsecFee       Float     @default(0)
  cdblCharges   Float     @default(0)
  brokerageComm Float     @default(0)
  bankCharges   Float     @default(0)
  totalExpenses Float     @default(0)

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("fund_expenses")
}

// ─── KYC ─────────────────────────────────────────────────────────
// KycType: NID, PASSPORT, SELFIE, TIN, AML_CHECK
// KycStatus: PENDING, VERIFIED, REJECTED, EXPIRED

model KycRecord {
  id              String    @id @default(cuid())
  investorId      String
  type            String
  status          String    @default("PENDING")
  documentUrl     String?
  selfieUrl       String?
  matchScore      Float?
  verifiedBy      String?
  rejectionReason String?
  expiresAt       DateTime?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("kyc_records")
}

// ─── Bank Account ────────────────────────────────────────────────

model BankAccount {
  id            String  @id @default(cuid())
  investorId    String
  bankName      String
  branchName    String?
  accountNumber String
  routingNumber String?
  chequeLeafUrl String?
  isPrimary     Boolean @default(false)
  // ACTIVE | PENDING_APPROVAL | REJECTED
  status        String  @default("ACTIVE")

  investor Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  sipPlans SipPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bank_accounts")
}

// ─── Nominee ─────────────────────────────────────────────────────

model Nominee {
  id           String  @id @default(cuid())
  investorId   String
  name         String
  relationship String?
  nidNumber    String?
  share        Float   @default(100)
  isMinor      Boolean @default(false)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nominees")
}

// ─── Consent ─────────────────────────────────────────────────────

model Consent {
  id         String    @id @default(cuid())
  investorId String
  type       String
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  ipAddress  String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@map("consents")
}

// ─── SIP Plan ────────────────────────────────────────────────────
// SipStatus: ACTIVE, PAUSED, CANCELLED

model SipPlan {
  id            String    @id @default(cuid())
  investorId    String
  fundId        String
  bankAccountId String?
  amount        Float
  frequency     String    @default("MONTHLY")
  debitDay      Int       @default(10)
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("ACTIVE")

  investor    Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund        Fund         @relation(fields: [fundId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@map("sip_plans")
}

// ─── Service Request / Ticketing ─────────────────────────────────

model ServiceRequest {
  id             String    @id @default(cuid())
  investorId     String
  type           String
  status         String    @default("OPEN")
  description    String?
  trackingNumber String    @unique
  slaDeadline    DateTime?

  investor Investor        @relation(fields: [investorId], references: [id], onDelete: Cascade)
  comments TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("service_requests")
}

model TicketComment {
  id               String  @id @default(cuid())
  serviceRequestId String
  authorId         String
  content          String
  attachmentUrl    String?

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ticket_comments")
}

// ─── Notification ────────────────────────────────────────────────

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String
  title   String
  message String
  isRead  Boolean @default(false)
  link    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Approval Queue (Maker-Checker) ─────────────────────────────
// ApprovalStatus: PENDING, APPROVED, REJECTED

model ApprovalQueue {
  id         String  @id @default(cuid())
  entityType String
  entityId   String
  makerId    String
  checkerId  String?
  status     String  @default("PENDING")
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("approval_queue")
}

// ─── Mail (SMTP settings + delivery logs) ────────────────────────

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String // JSON or plain text
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// MailLog: one row per outgoing email. Template = EFUF_PORTFOLIO |
// EGF_PORTFOLIO | ESRF_PORTFOLIO | TAX_CERT | WELCOME | CUSTOM.
// status = SENT | FAILED | OPENED. trackingId is used for the (future)
// open-tracking pixel endpoint.
model MailLog {
  id           String    @id @default(cuid())
  investorId   String?
  toEmail      String
  subject      String
  template     String
  status       String    @default("SENT")
  errorMessage String?
  openedAt     DateTime?
  trackingId   String    @unique @default(cuid())
  sentById     String?
  createdAt    DateTime  @default(now())

  investor Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  @@index([investorId])
  @@index([status])
  @@index([template])
  @@map("mail_logs")
}

// ─── Audit Log ───────────────────────────────────────────────────

model AuditLog {
  id        String  @id @default(cuid())
  userId    String
  // Snapshot of the user's email and role at the moment of the action —
  // kept separately from the FK so audit history remains accurate even if
  // the user is deactivated, renamed, or has their role changed later.
  userEmail String?
  userRole  String?
  action    String
  entity    String
  entityId  String?
  oldValue  String? // JSON as text
  newValue  String? // JSON as text
  ipAddress String?
  userAgent String?
  metadata  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ─── Document Vault ──────────────────────────────────────────────

model Document {
  id         String  @id @default(cuid())
  investorId String
  type       String
  fileName   String
  filePath   String
  mimeType   String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([investorId])
  @@map("documents")
}

// ─── Fund Report (admin-uploaded Excel reports per fund) ─────────

model FundReport {
  id         String    @id @default(cuid())
  fundId     String
  reportType String // FIN_STATS, INVESTORS, PORTFOLIO, NAV_HISTORY, EXPENSES, HOLDINGS
  title      String
  fileName   String
  filePath   String
  mimeType   String?
  reportDate DateTime?
  uploadedBy String?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([fundId])
  @@index([reportType])
  @@map("fund_reports")
}

// ─── Daily Fund Upload (FIN STATS / INVESTORS Excel, drives ingestion) ──

model DailyFundUpload {
  id            String    @id @default(cuid())
  fundId        String
  uploadType    String // FIN_STATS | INVESTORS
  reportDate    DateTime // the "as of" date encoded in the file
  fileName      String
  filePath      String
  mimeType      String?
  uploadedBy    String?
  status        String    @default("PENDING") // PENDING | PROCESSING | PROCESSED | FAILED
  processedAt   DateTime?
  error         String?
  rowsProcessed Int?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([fundId, uploadType])
  @@index([reportDate])
  @@map("daily_fund_uploads")
}

// ─── Comparison Report (PDFs like UCB Weekly MF Review) ──────────

model ComparisonReport {
  id         String    @id @default(cuid())
  title      String
  source     String? // e.g., "UCB Stock Brokerage"
  reportDate DateTime?
  fileName   String
  filePath   String
  mimeType   String?
  uploadedBy String?

  createdAt DateTime @default(now())

  @@map("comparison_reports")
}

// ─── Market Commentary (CMS) ─────────────────────────────────────

model MarketCommentary {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  category    String?
  publishedAt DateTime?
  authorId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("market_commentaries")
}

// ─── Investment Goal ─────────────────────────────────────────────
// GoalStatus: ACTIVE, ACHIEVED, ABANDONED

model InvestmentGoal {
  id              String   @id @default(cuid())
  investorId      String
  name            String
  targetAmount    Float
  lumpsumAmount   Float    @default(0)
  monthlySip      Float    @default(0)
  expectedReturn  Float    @default(10)
  timePeriodYears Int      @default(5)
  deadline        DateTime
  status          String   @default("ACTIVE")

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("investment_goals")
}

// ─── Knowledge Center ────────────────────────────────────────────
// Three admin-editable content types surfaced on the ekushwml.com
// /knowledge page's new 5-tab layout:
//   Video        → Video Library tab (YouTube videos)
//   Article      → Press & Articles tab (TBS / Financial Express / other)
//   LearnTopic   → Basic of Mutual Fund tab (icon-led expandable cards)
//
// FAQ and Myth Buster stay in the rebuild's static JSON for now —
// LearnTopic.category is left as an open String so those can migrate
// later without a schema change.

model Video {
  id           String   @id @default(cuid())
  // Full URL the admin pasted; we derive videoId from this but keep
  // the original so support can debug odd paste cases (shorts, etc.).
  youtubeUrl   String
  videoId      String   @unique
  title        String
  category     String // basics | strategy | tax | industry
  thumbnailUrl String
  duration     String // "14:32" — formatted at fetch time, not re-parsed
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  publishedAt  DateTime
  // At most ONE Video may have isFeatured=true at a time. Enforced
  // in the admin route handler via a transactional toggle-others-off
  // step (Prisma has no native "unique where true" constraint).
  isFeatured   Boolean  @default(false)
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  // Updated every time we re-fetch YouTube stats (daily cron + manual
  // refresh button). Lets admin see staleness at a glance.
  lastSyncedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@index([isFeatured])
  @@map("videos")
}

model Article {
  id              String   @id @default(cuid())
  articleUrl      String
  publisher       String // tbs | financial_express | other
  title           String
  excerpt         String
  coverImageUrl   String
  category        String // opinion | analysis | feature | interview
  publishedAt     DateTime
  readTimeMinutes Int
  displayOrder    Int      @default(0)
  isPublished     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("articles")
}

model LearnTopic {
  id           String   @id @default(cuid())
  title        String
  summary      String // one-liner shown in the list row ("Read · 4 min · …")
  body         String   @db.Text // HTML from TipTap
  iconKey      String // cube | layers | bank | chart  (extendable)
  // Multi-image gallery. The rebuild renders each image at its
  // native aspect ratio inside a coverflow slide; 2+ images turn the
  // card into a nested swipeable deck. Empty array → iconKey fallback.
  images       String[] @default([])
  // Deprecated single-cover column, kept so legacy rows still render.
  // The public API emits `images` with [imageUrl] filled in when
  // `images` is empty and `imageUrl` is set. Drop once every row has
  // migrated to the array column.
  imageUrl     String?
  category     String // basics (only used today)
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)

  // ── Surface visibility flags ──────────────────────────────────
  // isPublished is the master gate; `showOnTopic` and
  // `showInWhatsNew` decide *where* a published topic appears.
  // The two flags are independent: a topic can live on the Topic
  // tab only, in the What's New carousel only, or both.
  // showOnTopic defaults to true so existing rows keep showing on
  // /knowledge after the migration without any admin action.
  showOnTopic    Boolean @default(true)
  // The What's New floating tab pulls from topics that opt-in via
  // showInWhatsNew. Topics still need isPublished:true to appear
  // publicly — showInWhatsNew is a *feature flag*, not a publish
  // override.
  showInWhatsNew Boolean @default(false)
  // Lower number = shown first. NULL means "after all ordered
  // entries, then by createdAt desc". Kept nullable so admins can
  // toggle a topic into What's New without typing a number.
  whatsNewOrder  Int?

  // Investor portal /dashboard hero banner opt-in. Same shape as the
  // What's New pair: a boolean flag plus an optional order. Topics
  // with showInPortalBanner=true (and isPublished=true) are returned
  // by /api/public/portal-banner and rotate through the dashboard
  // banner carousel. When zero topics opt in the static
  // <TaxRebateBanner /> renders as the fallback.
  showInPortalBanner Boolean @default(false)
  portalBannerOrder  Int?

  // Optional CTA shown on the What's New slide — e.g. "Open Portal"
  // → portal login. Both fields are required together (null/null
  // hides the CTA). Validated at the API parser, not enforced in
  // the schema, so partial drafts can round-trip.
  ctaUrl   String?
  ctaLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isPublished, displayOrder])
  @@index([showOnTopic, isPublished, displayOrder])
  @@index([showInWhatsNew, whatsNewOrder])
  @@index([showInPortalBanner, portalBannerOrder])
  @@map("learn_topics")
}

// ── Ahona chatbot ────────────────────────────────────────────────
// Menu-driven assistant on both ekushwml.com (public) and the portal.
// Strictly button-tap navigation — no text input, no AI, no message
// persistence. Users only see admin-curated quick replies; out-of-
// scope routes them to call/WhatsApp. Bilingual (en + bn) in every
// content field.
model AhonaSettings {
  id               String   @id @default("singleton")
  enabledOnWebsite Boolean  @default(false)
  enabledOnPortal  Boolean  @default(false)
  // Greeting shown at the top of the panel before any menu choice.
  greetingEn       String   @default("Hi, I'm Ahona — how can I help?")
  greetingBn       String   @default("নমস্কার, আমি আহনা — কীভাবে সাহায্য করতে পারি?")
  // Phone + WhatsApp the contact-card leaves render as buttons. Stored
  // as digits-only (international, no leading +) so the wa.me/tel:
  // links can use them verbatim.
  phoneNumber      String?
  whatsappNumber   String?
  // Free-form text shown alongside the contact card so admins can
  // tell users when the line is staffed.
  workingHoursEn   String?
  workingHoursBn   String?
  updatedAt        DateTime @updatedAt
  updatedBy        String?

  @@map("ahona_settings")
}

// One node of the menu tree. parentId = null → top-level button.
// surface controls which mount point sees it; isContactCard turns
// the leaf into the phone/WhatsApp pair instead of a text response.
model AhonaQuickReply {
  id            String  @id @default(cuid())
  parentId      String?
  displayOrder  Int     @default(0)
  // Which mount sees this node: PUBLIC (only ekushwml.com), PORTAL
  // (only the investor portal), BOTH.
  surface       String  @default("BOTH")
  labelEn       String
  labelBn       String
  // Plain-text reply rendered as paragraphs (\n preserved). HTML is
  // stripped on render; we don't want a hostile-admin XSS path.
  responseEn    String  @default("")
  responseBn    String  @default("")
  // When true, the response area renders the AhonaSettings phone +
  // WhatsApp buttons instead of the response text. Lets every menu
  // tree have a "Talk to us" leaf without admin retyping the number.
  isContactCard Boolean @default(false)
  isPublished   Boolean @default(true)

  parent   AhonaQuickReply?  @relation("AhonaQuickReplyChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children AhonaQuickReply[] @relation("AhonaQuickReplyChildren")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, displayOrder])
  @@index([surface, isPublished])
  @@map("ahona_quick_replies")
}

// Singleton config for the What's New side-tab. Holds the global
// WhatsApp number the "Call on WhatsApp" CTA on every card opens.
// Stored as its own row (not on each LearnTopic) so admins can
// rotate the number once and have it apply across all cards.
model WhatsNewSetting {
  id             String   @id @default("singleton")
  // International format without the leading + (e.g. "8801713086101"),
  // or null when the admin hasn't configured one yet — in that case
  // the public side-tab hides the WhatsApp button.
  whatsappNumber String?
  updatedAt      DateTime @updatedAt
  updatedBy      String? // user id of the admin who last saved

  @@map("whats_new_settings")
}

// Admin-maintained Fund Fact Sheet — one row per fund code (EFUF,
// EGF, ESRF today). Populated manually today; a future cron can
// seed it by parsing the latest portfolio-statement PDF, with the
// admin form allowing overrides. JSON columns keep the row
// normalised against fund code while letting the shape evolve
// without schema churn.
//
//   assetAllocation: [{category: "Equity", weightPct: 65}, ...]
//   topHoldings:     [{ticker: "SQUAREPHARMA", name: "Square Pharma",
//                      weightPct: 7.2}, ...]
model FundFactSheet {
  id               String    @id @default(cuid())
  // Fund code as used in the rebuild's URL slug — "EFUF" / "EGF" /
  // "ESRF". Unique so the admin form is an upsert against this code.
  fundCode         String    @unique
  asOfDate         DateTime // quarter-end the data reflects
  // Asset allocation: the three buckets derived from the portfolio
  // statement — Stocks (Listed + Non-Listed), Bonds (typically 0%),
  // and Cash & Equivalents. Kept as free-form JSON so admins can
  // relabel or add categories without a migration.
  assetAllocation  Json      @default("[]")
  // Sector allocation: Bank / Pharmaceuticals / Close-end MF / etc.
  // Summed from the "% of total Investment" column on the listed
  // portfolio, grouped by the un-numbered sector header above each
  // block of rows. Stored as [{sector, weightPct}, ...].
  sectorAllocation Json      @default("[]")
  topHoldings      Json      @default("[]")
  // Source tracking: which portfolio-statement PDF the data was
  // pulled from (URL). Null until the first auto-extract lands.
  sourcePdfUrl     String?
  autoExtractedAt  DateTime?
  // Touched on every admin save so the public API can show a
  // "Last updated" hint if we ever want it.
  updatedBy        String? // user id of the admin who last saved
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("fund_fact_sheets")
}

// Singleton row (id hard-coded to "singleton") holding the URL of
// the image that should pop up on the rebuild's homepage PBSL-style.
// Pinning image B from the LearnTopic gallery overwrites A on this
// row; clearing it removes the popup site-wide. Kept as a dedicated
// model so reads are a single cheap findUnique.
model FrontPagePopup {
  id        String   @id @default("singleton")
  imageUrl  String?
  updatedAt DateTime @updatedAt

  @@map("front_page_popup")
}

// Admin-uploaded PDF research reports. Rendered as a Bridgewater-
// style card grid on /knowledge → "Research & Insights" tab, below
// the Myth Buster section. The PDF itself lives on Vercel Blob; the
// card links out to the file in a new tab.
model ResearchReport {
  id           String   @id @default(cuid())
  title        String
  description  String // 1–2 sentences shown on the public card
  pdfUrl       String // Vercel Blob URL, required
  pdfSizeBytes Int? // populated by the upload handler so the card
  // can show "PDF · 2.3 MB"
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("research_reports")
}

// ─── Prospect (Tier 1) ───────────────────────────────────────────
// Lightweight lead captured via the homepage WhatsApp signup. No KYC, no
// User row, no investor code — just a phone-keyed record so marketing
// can nurture them. When a prospect later completes KYC and is approved
// by admin, an Investor row is created and `Investor.linkedProspectId`
// points back here for conversion attribution.

model Prospect {
  id            String  @id @default(cuid())
  // Phone is the login identifier. Stored digits-only (no leading +,
  // no spaces, no dashes) so it round-trips cleanly to the Supabase
  // synthetic email "<phone>@prospect.ekush.local".
  phone         String  @unique
  phoneVerified Boolean @default(false)
  // Mirror auth.users.id from Supabase Auth, set after the synthetic-email
  // signup completes. Same pattern as User.supabaseId.
  supabaseId    String? @unique

  name         String
  email        String?
  passwordHash String

  // One of: "exploring" | "mutual_funds" | "sukuk" | "dpm" | "other".
  // Validated app-side; kept loose here so marketing can extend without
  // schema migration.
  interest String
  // Free-text attribution: "homepage_cta" | "facebook_ad"
  // | "click_to_whatsapp" | "referral" | … Loose by design.
  source   String?

  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?

  // True once the prospect has submitted the 4-step KYC. Stays true
  // even after admin approval so /admin/prospects can show the
  // "↗ KYC submitted" badge throughout the conversion lifecycle.
  kycSubmitted Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  // Soft delete — set when the prospect or admin deletes the account.
  // Cron purges rows older than `deletedAt + 30 days`.
  deletedAt   DateTime?

  // Back-reference to the Investor record created on KYC approval.
  // Optional 1:1 — populated only after conversion.
  linkedInvestor Investor?

  @@index([deletedAt])
  @@index([createdAt])
  @@map("prospects")
}

// ─── OTP codes ───────────────────────────────────────────────────
// SMS one-time-passwords for prospect signup. Hashed at rest (never
// store the plain 6-digit code). Cron purges rows past `expiresAt`.

model OtpCode {
  id       String @id @default(cuid())
  phone    String
  // bcrypt(code). The plaintext code is sent to the user via SMS and
  // never stored.
  codeHash String
  // v1 supports "PROSPECT_SIGNUP". Future: "PROSPECT_LOGIN_2FA",
  // "PHONE_CHANGE", etc.
  purpose  String @default("PROSPECT_SIGNUP")

  expiresAt   DateTime
  consumedAt  DateTime?
  // Failed verify attempts on this row — guards against brute-forcing
  // the 6-digit space.
  attempts    Int       @default(0)
  // Resend counter, scoped to (phone, purpose). The signup flow rejects
  // a 4th resend within the rolling window per the brief.
  resendCount Int       @default(0)

  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ─── User TOTP (admin 2FA) ───────────────────────────────────────
// One row per admin/staff account. Existing `User.twoFactorEnabled` and
// `User.twoFactorSecret` columns are vestigial (no code currently writes
// them); this dedicated table keeps the secret in a smaller surface area
// and leaves room for recovery-code expansion later.

model UserTotp {
  id     String @id @default(cuid())
  userId String @unique
  // Base32-encoded TOTP secret. v1 stores raw; column-level encryption
  // is a Phase 8 follow-up.
  secret String

  // Set when the user successfully verifies their first 6-digit code on
  // the QR-scan enrollment screen. Null = enrollment started but not
  // confirmed (the row exists so a refresh doesn't lose the secret).
  enrolledAt DateTime?
  // Last successful TOTP verification — used for replay protection
  // (reject the same code twice in a row within its 30-second window).
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_totp")
}

// ─── Login attempts (rate limit) ─────────────────────────────────
// One row per login attempt across both realms (investor / prospect).
// The login routes count failed rows in the last 15 minutes for the
// (identifier, ip) pair and block at 5. Cron purges rows older than 24h.

model LoginAttempt {
  id         String  @id @default(cuid())
  // Verbatim login string the caller submitted (investor code, phone,
  // or email). Lower-cased and trimmed before insert by the caller.
  identifier String
  ipAddress  String
  // "INVESTOR" | "PROSPECT" — keeps counters isolated so a hot prospect
  // tab doesn't lock out the investor tab and vice versa.
  realm      String
  success    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([identifier, ipAddress, realm, createdAt])
  @@index([createdAt])
  @@map("login_attempts")
}
