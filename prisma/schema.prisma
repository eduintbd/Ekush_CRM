generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth & Identity ─────────────────────────────────────────────
// UserRole: INVESTOR, ADMIN, MANAGER, COMPLIANCE, SUPPORT, SUPER_ADMIN
// UserStatus: PENDING, ACTIVE, SUSPENDED, CLOSED

model User {
  id               String   @id @default(cuid())
  // Email is NOT unique — family members investing under different investor
  // codes may legitimately share a single email. Login resolves ambiguity by
  // preferring the investor-code match; email lookups use findFirst.
  email            String?
  phone            String?
  // Display name for staff users. Investors have their name on the Investor
  // row; staff accounts don't have an Investor relation so we store it here.
  fullName         String?
  passwordHash     String
  supabaseId       String?  @unique
  // Values are constrained by src/lib/roles.ts: SUPER_ADMIN | MAKER | CHECKER
  // | VIEWER for staff, or INVESTOR for end-user accounts.
  role             String   @default("INVESTOR")
  status           String   @default("PENDING") // INVITED | ACTIVE | LOCKED | DEACTIVATED | PENDING | SUSPENDED | CLOSED
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  // Who invited this user (staff only; investors self-register).
  createdById      String?

  createdBy     User?          @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers  User[]         @relation("UserCreatedBy")
  invitesSent   Invitation[]   @relation("InvitedBy")
  resetTokens   PasswordResetToken[]
  investor      Investor?
  auditLogs     AuditLog[]
  notifications Notification[]
  sessions      Session[]

  @@index([status])
  @@index([role])
  @@index([email])
  @@map("users")
}

// Staff invitations. A Super Admin creates a row with a one-time token
// (hash is stored here; raw token is emailed). On acceptance, the invitee
// sets a password and we mark acceptedAt.
model Invitation {
  id         String    @id @default(cuid())
  email      String
  fullName   String
  role       String    // SUPER_ADMIN | MAKER | CHECKER | VIEWER
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  note       String?
  invitedById String?

  invitedBy  User?     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

// Self-serve password reset. One-time token; hash stored here, raw token
// emailed. usedAt marks the token as consumed so a second click 404s.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Investor ────────────────────────────────────────────────────
// InvestorType: INDIVIDUAL, COMPANY_ORGANIZATION, MUTUAL_FUND, PROVIDENT_FUND, GRATUITY_FUND

model Investor {
  id           String   @id @default(cuid())
  userId       String   @unique
  investorCode String   @unique
  name         String
  title        String?
  investorType String   @default("INDIVIDUAL")
  nidNumber    String?
  tinNumber    String?
  dateOfBirth  DateTime?
  address      String?
  riskProfile  String?
  boId         String?
  // DP (Depository Participant) ID and brokerage house — completes the BO/demat
  // account triple. Populated from the 'BO ID- NEW / DP ID- NEW / Brokerage
  // House Name- NEW' columns in Investors Database.xlsx.
  dpId            String?
  brokerageHouse  String?
  // Family names — sourced from 'Father Name / Mother Name / Spouse Name'
  // columns in the Investors Database workbook. Used on printed forms.
  fatherName      String?
  motherName      String?
  spouseName      String?
  dividendOption String @default("CASH") // CASH | CIP
  // Digital signature image URL (optional — wet signature on file is the fallback).
  // Used on auto-generated DDI forms.
  signatureUrl String?
  // Timestamp of the one-time welcome email sent on PENDING→ACTIVE approval.
  // Null means never sent — manual "Send Now" in the admin edit form uses
  // this flag to show the retry UI.
  welcomeEmailSentAt DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings        FundHolding[]
  transactions    Transaction[]
  dividends       Dividend[]
  taxCertificates TaxCertificate[]
  kycRecords      KycRecord[]
  bankAccounts    BankAccount[]
  nominees        Nominee[]
  consents        Consent[]
  documents       Document[]
  serviceRequests  ServiceRequest[]
  sipPlans         SipPlan[]
  investmentGoals  InvestmentGoal[]
  mailLogs         MailLog[]
  ddiInstructions  DdiInstruction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("investors")
}

// ─── Fund ────────────────────────────────────────────────────────

model Fund {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  fundType      String?
  description   String?
  objective     String?
  inceptionDate DateTime?
  currentNav    Float     @default(0)
  previousNav   Float     @default(0)
  totalAum      Float     @default(0)
  totalUnits    Float     @default(0)
  faceValue     Float     @default(10)

  managementFeeRate Float @default(0)
  trusteeFeeRate    Float @default(0)
  custodianFeeRate  Float @default(0)
  entryLoad         Float @default(0)
  exitLoad          Float @default(0)
  minInvestment     Float @default(0)
  minSipAmount      Float @default(0)

  holdings            FundHolding[]
  transactions        Transaction[]
  navRecords          NavRecord[]
  dividends           Dividend[]
  taxCertificates     TaxCertificate[]
  financialStatements FinancialStatement[]
  fundExpenses        FundExpense[]
  sipPlans            SipPlan[]
  fundReports         FundReport[]
  dailyUploads        DailyFundUpload[]
  ddiInstructions     DdiInstruction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("funds")
}

// ─── Fund Holding (per investor per fund) ────────────────────────

model FundHolding {
  id         String @id @default(cuid())
  investorId String
  fundId     String

  // Lump Sum fields
  lsUnitsBought      Float @default(0)
  lsUnitsSold        Float @default(0)
  lsCurrentUnits     Float @default(0)
  lsCostValue        Float @default(0)
  lsCostOfUnitsSold  Float @default(0)
  lsCostValueCurrent Float @default(0)
  lsRealizedGain     Float @default(0)
  lsWeight           Float @default(0)
  lsAvgCost          Float @default(0)
  lsMarketValue      Float @default(0)

  // SIP fields
  sipUnitsBought      Float @default(0)
  sipUnitsSold        Float @default(0)
  sipCurrentUnits     Float @default(0)
  sipCostValue        Float @default(0)
  sipCostOfUnitsSold  Float @default(0)
  sipCostValueCurrent Float @default(0)
  sipRealizedGain     Float @default(0)
  sipWeight           Float @default(0)
  sipAvgCost          Float @default(0)
  sipMarketValue      Float @default(0)

  // Consolidated
  totalUnitsBought      Float @default(0)
  totalUnitsSold        Float @default(0)
  boOpeningBalance      Float @default(0)
  totalCurrentUnits     Float @default(0)
  totalCostValueCurrent Float @default(0)
  avgCost               Float @default(0)
  nav                   Float @default(0)
  totalMarketValue      Float @default(0)
  totalSellableUnits    Float @default(0)
  marketValueSellable   Float @default(0)
  totalRealizedGain     Float @default(0)
  totalUnrealizedGain   Float @default(0)
  percentUnitsHold      Float @default(0)

  // Gross Dividend (from simpler fund files)
  grossDividend Float @default(0)

  // XIRR-based annualized return (from T. History sheet in INVESTORS.xlsx)
  annualizedReturn Float @default(0)

  // First purchase date (earliest LS/SIP transaction); used for return calculations
  firstPurchaseDate DateTime?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([investorId, fundId])
  @@index([fundId])
  @@map("fund_holdings")
}

// ─── Transaction ─────────────────────────────────────────────────
// Channel: LS, SIP
// Direction: BUY, SELL
// Status: PENDING, IN_PROCESS, EXECUTED, REJECTED

model Transaction {
  id              String   @id @default(cuid())
  investorId      String
  fundId          String
  channel         String   // LS or SIP
  direction       String   // BUY or SELL
  amount          Float    @default(0)
  nav             Float    @default(0)
  units           Float    @default(0)
  cumulativeUnits Float    @default(0)
  unitCapital     Float    @default(0)
  unitPremium     Float    @default(0)
  avgCostAtTime   Float    @default(0)
  realizedGain    Float    @default(0)
  costOfUnitsSold Float    @default(0)
  uniqueCode      String?
  orderDate       DateTime
  status          String   @default("EXECUTED")
  paymentMethod   String?  // BANK_TRANSFER | DDI
  paymentRef      String?
  notes           String?

  investor       Investor        @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund           Fund            @relation(fields: [fundId], references: [id], onDelete: Cascade)
  ddiInstruction DdiInstruction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId, fundId])
  @@index([orderDate])
  @@index([status])
  @@map("transactions")
}

// ─── DDI Instruction (one-time buy via Direct Debit) ─────────────
// Created when an investor authorizes Ekush to pull the buy amount
// from their registered bank account instead of uploading a slip.
// Links 1:1 to a Transaction. Signature is optional — a null value
// means "use the wet signature on file at Ekush".

model DdiInstruction {
  id              String   @id @default(cuid())
  investorId      String
  fundId          String
  transactionId   String?  @unique
  amount          Float
  signatureUrl    String?  // snapshot at signing time; null = wet sig on file
  termsAccepted   Boolean  @default(false)
  status          String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | EXECUTED | CANCELLED
  applicationDate DateTime @default(now())
  adminNotes      String?

  investor    Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund        Fund         @relation(fields: [fundId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([fundId])
  @@index([status])
  @@map("ddi_instructions")
}

// ─── NAV Record ──────────────────────────────────────────────────

model NavRecord {
  id             String   @id @default(cuid())
  fundId         String
  date           DateTime
  nav            Float
  // Authoritative cumulative dividend-adjusted total return % from the
  // upstream xlsx ("Investor Return" column). Source of truth — not
  // recomputed from NAV. Nullable for rows imported before the column
  // existed.
  investorReturn Float?
  buyUnit        Float?
  sellUnit       Float?
  dsex           Float?
  ds30           Float?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, date])
  @@map("nav_records")
}

// ─── Dividend ────────────────────────────────────────────────────
// DividendOption: CASH, CIP

model Dividend {
  id              String    @id @default(cuid())
  investorId      String
  fundId          String
  accountingYear  String?
  paymentDate     DateTime?
  totalUnits      Float     @default(0)
  dividendPerUnit Float     @default(0)
  grossDividend   Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  netDividend     Float     @default(0)
  dividendOption  String    @default("CASH")
  tinNumber       String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([investorId, fundId])
  @@map("dividends")
}

// ─── Tax Certificate ─────────────────────────────────────────────

model TaxCertificate {
  id         String @id @default(cuid())
  investorId String
  fundId     String

  periodStart DateTime?
  periodEnd   DateTime?

  beginningUnits          Float @default(0)
  beginningCostValue      Float @default(0)
  beginningMarketValue    Float @default(0)
  beginningUnrealizedGain Float @default(0)

  endingUnits          Float @default(0)
  endingCostValue      Float @default(0)
  endingMarketValue    Float @default(0)
  endingUnrealizedGain Float @default(0)

  totalUnitsAdded       Float @default(0)
  totalAdditionAtCost   Float @default(0)
  totalUnitsRedeemed    Float @default(0)
  totalRedemptionAtCost Float @default(0)
  netInvestment         Float @default(0)
  totalRealizedGain     Float @default(0)
  totalGrossDividend    Float @default(0)
  totalTax              Float @default(0)
  totalNetDividend      Float @default(0)
  navAtEnd              Float @default(0)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund     Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([investorId, fundId, periodEnd], name: "investorId_fundId_periodEnd")
  @@index([investorId, fundId])
  @@map("tax_certificates")
}

// ─── Financial Statement ─────────────────────────────────────────

model FinancialStatement {
  id          String    @id @default(cuid())
  fundId      String
  type        String    // BS, IS, CF, EQUITY
  periodStart DateTime?
  periodEnd   DateTime?
  data        String    // JSON stored as text (SQLite doesn't support Json)

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("financial_statements")
}

// ─── Fund Expense ────────────────────────────────────────────────

model FundExpense {
  id            String    @id @default(cuid())
  fundId        String
  periodStart   DateTime?
  periodEnd     DateTime?
  managementFee Float     @default(0)
  trusteeFee    Float     @default(0)
  custodianFee  Float     @default(0)
  auditFee      Float     @default(0)
  bsecFee       Float     @default(0)
  cdblCharges   Float     @default(0)
  brokerageComm Float     @default(0)
  bankCharges   Float     @default(0)
  totalExpenses Float     @default(0)

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("fund_expenses")
}

// ─── KYC ─────────────────────────────────────────────────────────
// KycType: NID, PASSPORT, SELFIE, TIN, AML_CHECK
// KycStatus: PENDING, VERIFIED, REJECTED, EXPIRED

model KycRecord {
  id              String    @id @default(cuid())
  investorId      String
  type            String
  status          String    @default("PENDING")
  documentUrl     String?
  selfieUrl       String?
  matchScore      Float?
  verifiedBy      String?
  rejectionReason String?
  expiresAt       DateTime?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("kyc_records")
}

// ─── Bank Account ────────────────────────────────────────────────

model BankAccount {
  id            String  @id @default(cuid())
  investorId    String
  bankName      String
  branchName    String?
  accountNumber String
  routingNumber String?
  chequeLeafUrl String?
  isPrimary     Boolean @default(false)
  // ACTIVE | PENDING_APPROVAL | REJECTED
  status        String  @default("ACTIVE")

  investor Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  sipPlans SipPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bank_accounts")
}

// ─── Nominee ─────────────────────────────────────────────────────

model Nominee {
  id           String  @id @default(cuid())
  investorId   String
  name         String
  relationship String?
  nidNumber    String?
  share        Float   @default(100)
  isMinor      Boolean @default(false)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nominees")
}

// ─── Consent ─────────────────────────────────────────────────────

model Consent {
  id         String    @id @default(cuid())
  investorId String
  type       String
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  ipAddress  String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@map("consents")
}

// ─── SIP Plan ────────────────────────────────────────────────────
// SipStatus: ACTIVE, PAUSED, CANCELLED

model SipPlan {
  id            String    @id @default(cuid())
  investorId    String
  fundId        String
  bankAccountId String?
  amount        Float
  frequency     String    @default("MONTHLY")
  debitDay      Int       @default(10)
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("ACTIVE")

  investor    Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  fund        Fund         @relation(fields: [fundId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@map("sip_plans")
}

// ─── Service Request / Ticketing ─────────────────────────────────

model ServiceRequest {
  id             String    @id @default(cuid())
  investorId     String
  type           String
  status         String    @default("OPEN")
  description    String?
  trackingNumber String    @unique
  slaDeadline    DateTime?

  investor Investor        @relation(fields: [investorId], references: [id], onDelete: Cascade)
  comments TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("service_requests")
}

model TicketComment {
  id               String @id @default(cuid())
  serviceRequestId String
  authorId         String
  content          String
  attachmentUrl    String?

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ticket_comments")
}

// ─── Notification ────────────────────────────────────────────────

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String
  title   String
  message String
  isRead  Boolean @default(false)
  link    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Approval Queue (Maker-Checker) ─────────────────────────────
// ApprovalStatus: PENDING, APPROVED, REJECTED

model ApprovalQueue {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  makerId    String
  checkerId  String?
  status     String   @default("PENDING")
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("approval_queue")
}

// ─── Mail (SMTP settings + delivery logs) ────────────────────────

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON or plain text
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// MailLog: one row per outgoing email. Template = EFUF_PORTFOLIO |
// EGF_PORTFOLIO | ESRF_PORTFOLIO | TAX_CERT | WELCOME | CUSTOM.
// status = SENT | FAILED | OPENED. trackingId is used for the (future)
// open-tracking pixel endpoint.
model MailLog {
  id           String    @id @default(cuid())
  investorId   String?
  toEmail      String
  subject      String
  template     String
  status       String    @default("SENT")
  errorMessage String?
  openedAt     DateTime?
  trackingId   String    @unique @default(cuid())
  sentById     String?
  createdAt    DateTime  @default(now())

  investor Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  @@index([investorId])
  @@index([status])
  @@index([template])
  @@map("mail_logs")
}

// ─── Audit Log ───────────────────────────────────────────────────

model AuditLog {
  id        String  @id @default(cuid())
  userId    String
  // Snapshot of the user's email and role at the moment of the action —
  // kept separately from the FK so audit history remains accurate even if
  // the user is deactivated, renamed, or has their role changed later.
  userEmail String?
  userRole  String?
  action    String
  entity    String
  entityId  String?
  oldValue  String? // JSON as text
  newValue  String? // JSON as text
  ipAddress String?
  userAgent String?
  metadata  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ─── Document Vault ──────────────────────────────────────────────

model Document {
  id         String @id @default(cuid())
  investorId String
  type       String
  fileName   String
  filePath   String
  mimeType   String?

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([investorId])
  @@map("documents")
}

// ─── Fund Report (admin-uploaded Excel reports per fund) ─────────

model FundReport {
  id         String   @id @default(cuid())
  fundId     String
  reportType String   // FIN_STATS, INVESTORS, PORTFOLIO, NAV_HISTORY, EXPENSES, HOLDINGS
  title      String
  fileName   String
  filePath   String
  mimeType   String?
  reportDate DateTime?
  uploadedBy String?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([fundId])
  @@index([reportType])
  @@map("fund_reports")
}

// ─── Daily Fund Upload (FIN STATS / INVESTORS Excel, drives ingestion) ──

model DailyFundUpload {
  id             String   @id @default(cuid())
  fundId         String
  uploadType     String   // FIN_STATS | INVESTORS
  reportDate     DateTime // the "as of" date encoded in the file
  fileName       String
  filePath       String
  mimeType       String?
  uploadedBy     String?
  status         String   @default("PENDING") // PENDING | PROCESSING | PROCESSED | FAILED
  processedAt    DateTime?
  error          String?
  rowsProcessed  Int?

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([fundId, uploadType])
  @@index([reportDate])
  @@map("daily_fund_uploads")
}

// ─── Comparison Report (PDFs like UCB Weekly MF Review) ──────────

model ComparisonReport {
  id         String   @id @default(cuid())
  title      String
  source     String?  // e.g., "UCB Stock Brokerage"
  reportDate DateTime?
  fileName   String
  filePath   String
  mimeType   String?
  uploadedBy String?

  createdAt DateTime @default(now())

  @@map("comparison_reports")
}

// ─── Market Commentary (CMS) ─────────────────────────────────────

model MarketCommentary {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  category    String?
  publishedAt DateTime?
  authorId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("market_commentaries")
}

// ─── Investment Goal ─────────────────────────────────────────────
// GoalStatus: ACTIVE, ACHIEVED, ABANDONED

model InvestmentGoal {
  id               String   @id @default(cuid())
  investorId       String
  name             String
  targetAmount     Float
  lumpsumAmount    Float    @default(0)
  monthlySip       Float    @default(0)
  expectedReturn   Float    @default(10)
  timePeriodYears  Int      @default(5)
  deadline         DateTime
  status           String   @default("ACTIVE")

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([status])
  @@map("investment_goals")
}
